# ─── Groq ────────────────────────────────────────────────────────
# Obtén tu API key gratis en: https://console.groq.com
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXX

# Modelo a usar (puedes cambiar por otro de Groq)
# Opciones: llama-3.3-70b-versatile | mixtral-8x7b-32768 | gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Servidor ───────────────────────────────────────────────────
PORT=3001

# URL del frontend (para CORS). En producción pon tu URL de Vercel.
# Ej: https://mathmentor.vercel.app
# En desarrollo puedes dejarlo en * o http://localhost:5173
FRONTEND_URL=*
